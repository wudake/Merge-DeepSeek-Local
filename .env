# ==========================================
# App 统一环境变量
# 共享于所有微服务
# ==========================================

# --- JWT ---
JWT_SECRET=app-shared-jwt-secret-change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --- PostgreSQL ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password

# --- OpenAI (视频脚本提取用) ---
OPENAI_API_KEY=

# --- 脚本服务 API Key (过渡期兼容) ---
SCRIPTS_API_KEY=dev-api-key-change-me
